{
  "name": "knoux-ai-clipboard-pro",
  "version": "1.0.0",
  "description": "AI-powered clipboard manager by KNOUX.",
  "author": "Eng. Sadek Elgazar (Knoux)",
  "private": true,
  "main": "main.js",
  "homepage": "https://knoux.store",
  "scripts": {
    "dev:renderer": "vite --host 0.0.0.0",
    "dev:main": "wait-on http://localhost:3000 && electron . --dev",
    "dev": "concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:main\"",
    "electron:dev": "concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:main\"",
    "start": "electron .",
    "build:renderer": "vite build",
    "build:main": "tsc --project tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder --win nsis portable",
    "pack": "npm run build && electron-builder --dir",
    "doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/knoux-production-doctor.ps1",
    "knoux:build-local": "powershell -ExecutionPolicy Bypass -File ./scripts/knoux-build-local.ps1",
    "test": "npm run doctor"
  },
  "dependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/sqlite3": "^3.1.11",
    "@xenova/transformers": "^2.17.2",
    "diff-match-patch": "^1.0.5",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "sqlite3": "^5.1.7",
    "ws": "^8.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.5.7",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "electron": "^25.9.8",
    "electron-builder": "^26.4.0",
    "electron-packager": "^17.1.2",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^5.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "store.knoux.ai.clipboard.pro",
    "productName": "Knoux AI Clipboard Pro",
    "copyright": "Copyright © 2026 KNOUX — Eng. Sadek Elgazar",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "assets/**/*",
      "public/**/*",
      "app/backend/**/*.js",
      "app/instant-config.json",
      ".env.example"
    ],
    "extraMetadata": {
      "name": "knoux-ai-clipboard-pro",
      "productName": "Knoux AI Clipboard Pro",
      "author": "Eng. Sadek Elgazar (Knoux)",
      "homepage": "https://knoux.store"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sqlite3/**/*",
      "node_modules/@mapbox/node-pre-gyp/**/*",
      "node_modules/@xenova/transformers/**/*"
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Knoux-AI-Clipboard-Pro-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Knoux AI Clipboard Pro"
    }
  }
}
