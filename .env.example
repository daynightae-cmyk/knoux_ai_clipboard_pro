# KNOUX AI Clipboard Pro — Environment Example
# Copy to .env locally only. Never commit real secrets.
# Vercel Production/Preview/Development must receive these from Project Settings.

NODE_ENV=development
PORT=3000

# OpenRouter AI Provider
# Never expose this as VITE_OPENROUTER_API_KEY and never commit a real key.
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=cohere/north-mini-code:free
OPENROUTER_MODEL_FALLBACKS=openrouter/auto
OPENROUTER_SITE_URL=https://knoux.store
OPENROUTER_APP_NAME=Knoux AI Clipboard Pro
OPENROUTER_DEBUG=false

# Optional server-to-server / Electron main-process proxy secret.
# Leave empty unless the caller sends the matching x-knoux-ai-secret header.
KNOUX_AI_PROXY_SECRET=

# Local database
DATABASE_URL=file:./data/knoux-ai-clipboard.sqlite

# App Branding
APP_NAME=Knoux AI Clipboard Pro
APP_BRAND=KNOUX
APP_WEBSITE=https://knoux.store
APP_DEVELOPER=Eng. Sadek Elgazar (Knoux)

# Security
ENABLE_LOCAL_FIRST_STORAGE=true
ENABLE_AI_LOGGING=false
MASK_SENSITIVE_DATA=true
