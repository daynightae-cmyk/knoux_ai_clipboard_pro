# KNOUX AI Clipboard Pro — Environment Example
# Copy to .env locally only. Never commit real secrets.

NODE_ENV=development
PORT=3000

# OpenRouter AI Provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=cohere/north-mini-code:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://knoux.store
OPENROUTER_APP_NAME=Knoux AI Clipboard Pro

# Local database
DATABASE_URL=file:./data/knoux-ai-clipboard.sqlite

# App Branding
APP_NAME=Knoux AI Clipboard Pro
APP_BRAND=KNOUX
APP_WEBSITE=https://knoux.store
APP_DEVELOPER=Eng. Sadek Elgazar (Knoux)

# Security
ENABLE_LOCAL_FIRST_STORAGE=true
ENABLE_AI_LOGGING=false
MASK_SENSITIVE_DATA=true
