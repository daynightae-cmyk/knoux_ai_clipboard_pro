# ============================================================
# KNOUX AI Clipboard Pro — Git Ignore
# ============================================================

# Dependencies
node_modules/
.pnp/
.pnp.js

# Environment / secrets
.env
.env.*
!.env.example

# Build outputs
dist/
build/
out/
release/
.next/
.vite/
.turbo/
.cache/
.parcel-cache/

# Electron Builder
*.blockmap
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.msi
*.nsis.7z

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests / coverage
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Temporary
tmp/
temp/
*.tmp
*.bak
*.old

# Local databases and runtime data
*.sqlite
*.sqlite3
*.db
data/*.sqlite
data/*.sqlite3
data/*.db
userdata/
scan-output/

# Keep docs and safe examples
!docs/
!.env.example
