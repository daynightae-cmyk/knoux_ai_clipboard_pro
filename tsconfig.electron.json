{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2020"],
    "outDir": "build",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "declaration": false,
    "noEmit": false,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "app/backend/main/**/*.ts",
    "app/backend/ipc/**/*.ts",
    "app/backend/init.ts",
    "app/backend/security/**/*.ts",
    "app/shared/**/*.ts",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "release",
    "app/renderer/**/*",
    "app/tests/**/*",
    "app/backend/ai/**/*",
    "app/backend/services/**/*",
    "app/backend/storage/**/*"
  ]
}
